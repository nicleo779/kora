<idea-plugin>
    <id>com.nicleo.fastsql.idea</id>
    <name>FastSql</name>
    <vendor email="support@nicleo.com">nicleo</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <annotator language="JAVA" implementationClass="com.nicleo.fastsql.idea.FastSqlAnnotator"/>
        <completion.contributor language="JAVA" implementationClass="com.nicleo.fastsql.idea.FastSqlCompletionContributor"/>
    </extensions>
</idea-plugin>
